import { useState, useEffect } from "react"
import { useAuth } from '../contexts/AuthContext';
import { theme } from '../config/theme';
import { PageStyles } from '../config/PageStyles';
import { Button, Alert, Card, Flex } from '../components/ThemeComponents';
import {
  Upload,
  FileText,
  CheckCircle,
  AlertCircle,
  TrendingUp,
  AlertTriangle,
} from "lucide-react"

export default function EstructuraPresupuestariaUpload() {
  const { token } = useAuth();
  const [file, setFile] = useState(null)
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState(null)
  const [success, setSuccess] = useState(false)
  const [summary, setSummary] = useState(null)
  const [summaryLoading, setSummaryLoading] = useState(true)
  const [showUploadForm, setShowUploadForm] = useState(false)
  const [isMobile, setIsMobile] = useState(window.innerWidth < 768);

  useEffect(() => {
    fetchSummary();
    const handleResize = () => {
      setIsMobile(window.innerWidth < 768);
    };
    window.addEventListener('resize', handleResize);
    return () => window.removeEventListener('resize', handleResize);
  }, [token])

  const fetchSummary = async () => {
    try {
      setSummaryLoading(true)
      const response = await fetch(
        `${import.meta.env.VITE_API_URL}/estructura-presupuestaria/summary`,
        {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        }
      )
      const data = await response.json()
      if (data.status === 'success' || data.success) {
        setSummary(data.data || data)
      } else {
        console.warn("Unexpected response format:", data)
      }
    } catch (err) {
      console.error("Error fetching summary:", err)
    } finally {
      setSummaryLoading(false)
    }
  }

  const validateFile = (selectedFile) => {
    if (selectedFile && selectedFile.name.endsWith(".csv")) {
      setFile(selectedFile)
      setError(null)
      return true
    } else {
      setError("Por favor selecciona un archivo CSV válido")
      setFile(null)
      return false
    }
  }

  const handleFileChange = (e) => {
    const selectedFile = e.target.files?.[0]
    if (selectedFile) {
      validateFile(selectedFile)
    }
  }

  const uploadFile = async (fileToUpload) => {
    setLoading(true)
    setError(null)
    setSuccess(false)

    try {
      const formData = new FormData()
      formData.append("csv_file", fileToUpload)

      const response = await fetch(
        `${import.meta.env.VITE_API_URL}/estructura-presupuestaria/upload`,
        {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
          },
          body: formData,
        }
      )

      const data = await response.json()

      if (data.success || data.status === 'success') {
        setSuccess(true)
        setFile(null)
        setShowUploadForm(false)
        setTimeout(() => setSuccess(false), 5000)
        fetchSummary()
      } else {
        setError(data.message || "Error al cargar el archivo")
      }
    } catch (err) {
      setError("Error: " + (err instanceof Error ? err.message : "Unknown error"))
    } finally {
      setLoading(false)
    }
  }

  const handleUpload = (e) => {
    e.preventDefault()
    if (file) {
      uploadFile(file)
    }
  }

  return (
    <div style={{
      padding: isMobile ? theme.spacing.lg : theme.spacing.xl,
      background: theme.colors.gray['100'],
      fontFamily: theme.typography.fontFamily,
      minHeight: '100vh',
    }}>
      <h1 style={PageStyles.pageTitle}>📤 Cargar Estructura Presupuestaria</h1>

      {/* Alertas */}
      {error && <Alert variant="error" style={{ marginBottom: theme.spacing.lg }}>{error}</Alert>}
      {success && <Alert variant="success" style={{ marginBottom: theme.spacing.lg }}>✓ Archivo cargado exitosamente</Alert>}

      {/* Card Upload */}
      <Card padding="lg" shadow="md" style={{ marginBottom: theme.spacing.xl }}>
        {!showUploadForm ? (
          <div style={{
            textAlign: 'center',
            padding: theme.spacing.xl,
          }}>
            <Upload size={48} style={{ color: theme.colors.primary, margin: `0 auto ${theme.spacing.lg}` }} />
            <h2 style={{
              ...PageStyles.sectionHeader,
              margin: `0 0 ${theme.spacing.md} 0`,
            }}>
              Importar Archivo CSV
            </h2>
            <p style={{
              color: theme.colors.text.secondary,
              marginBottom: theme.spacing.lg,
            }}>
              Carga un archivo CSV con la estructura presupuestaria
            </p>
            <Button variant="primary" onClick={() => setShowUploadForm(true)}>
              Seleccionar Archivo
            </Button>
          </div>
        ) : (
          <form onSubmit={handleUpload} style={{
            display: 'flex',
            flexDirection: 'column',
            gap: theme.spacing.lg,
          }}>
            <div style={{
              border: `2px dashed ${theme.colors.primary}`,
              borderRadius: theme.border.radiusMd,
              padding: theme.spacing.lg,
              textAlign: 'center',
              background: theme.colors.primary + '10',
            }}>
              <input
                type="file"
                accept=".csv"
                onChange={handleFileChange}
                style={{ display: 'none' }}
                id="file-input"
              />
              <label htmlFor="file-input" style={{
                display: 'block',
                cursor: 'pointer',
              }}>
                <FileText size={48} style={{ color: theme.colors.primary, margin: `0 auto ${theme.spacing.md}` }} />
                <p style={{
                  color: theme.colors.text.primary,
                  margin: 0,
                  fontWeight: theme.typography.fontWeight.bold,
                }}>
                  {file ? file.name : 'Haz clic para seleccionar archivo'}
                </p>
              </label>
            </div>
            <div style={{
              display: 'flex',
              gap: theme.spacing.md,
              justifyContent: 'center',
            }}>
              <Button variant="primary" type="submit" disabled={!file || loading}>
                {loading ? '⏳ Cargando...' : '📤 Subir'}
              </Button>
              <Button variant="secondary" onClick={() => setShowUploadForm(false)}>
                Cancelar
              </Button>
            </div>
          </form>
        )}
      </Card>

      {/* Summary */}
      {summary && (
        <Card padding="lg" shadow="md">
          <h2 style={PageStyles.sectionHeader}>Resumen Actual</h2>
          <div style={{
            display: 'grid',
            gridTemplateColumns: isMobile ? '1fr' : 'repeat(5, 1fr)',
            gap: theme.spacing.lg,
            marginTop: theme.spacing.lg,
          }}>
            {[
              { label: 'Programas', value: summary.programas_count || 0, icon: '📌' },
              { label: 'Subprogramas', value: summary.subprogramas_count || 0, icon: '📋' },
              { label: 'Proyectos', value: summary.proyectos_count || 0, icon: '🎯' },
              { label: 'Actividades', value: summary.actividades_count || 0, icon: '✓' },
              { label: 'Items', value: summary.items_count || 0, icon: '📦' },
            ].map((item, idx) => (
              <div key={idx} style={{
                ...PageStyles.card,
                textAlign: 'center',
              }}>
                <div style={{ fontSize: '2rem', marginBottom: theme.spacing.sm }}>
                  {item.icon}
                </div>
                <p style={{
                  color: theme.colors.text.secondary,
                  fontSize: theme.typography.fontSize.sm,
                  margin: `0 0 ${theme.spacing.xs} 0`,
                }}>
                  {item.label}
                </p>
                <p style={{
                  color: theme.colors.primary,
                  fontSize: theme.typography.fontSize['2xl'],
                  fontWeight: theme.typography.fontWeight.bold,
                  margin: 0,
                }}>
                  {item.value}
                </p>
              </div>
            ))}
          </div>
        </Card>
      )}
    </div>
  )
}

